# Copy to .env and fill in. marketlab reads these via pydantic-settings.

# ---- Data providers ----
# Polygon.io free tier: https://polygon.io/  (5 req/min on free tier)
POLYGON_API_KEY=

# Which provider ingest uses by default: "polygon" or "yfinance".
# yfinance needs no key and works out of the box, so it is the default.
MARKETLAB_PROVIDER=yfinance

# ---- Storage ----
# Root of the Parquet data lake (partitioned by symbol/year).
MARKETLAB_PARQUET_ROOT=./data/lake

# Postgres for symbol metadata + backtest results (docker-compose spins one up).
# Leave DSN empty to disable the Postgres layer entirely (Parquet still works).
MARKETLAB_PG_DSN=postgresql://marketlab:marketlab@localhost:5432/marketlab
